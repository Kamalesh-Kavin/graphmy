<!DOCTYPE html>
{#
  graphmy/viz/templates/graph.html.j2
  =====================================
  Self-contained static tree-view for a graphmy knowledge graph.

  Zero external dependencies. No NL query bar. No source bodies.
  Designed to stay under 2 MB for large codebases.

  Template variables:
    tree_json      : str   — slim tree nodes [{id,name,kind,file,line,is_async,children}]
    detail_json    : str   — flat {node_id: {end_line?,children_summary?}} (static only; no sig/doc)
    all_nodes_json : str   — flat [{id,name,kind,file,line}] for search
    project_name   : str
    node_count     : int
    edge_count     : int
    file_count     : int
    generated_at   : str
    graphmy_version: str

  Layout:
    ┌──────────────────────────────────────────────┐
    │  toolbar: title · stats · search             │
    ├────────────────────┬─────────────────────────┤
    │  tree panel        │  detail panel (on click) │
    │  folder ▶          │  kind · location         │
    │    file.py ▶       │  signature               │
    │      class Foo ▶   │  docstring               │
    │        def bar     │  contains summary        │
    └────────────────────┴─────────────────────────┘
#}
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>graphmy — {{ project_name }}</title>
  <style>
    /* reset */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0f1117;
      --bg2:       #1a1d2e;
      --bg3:       #1e2235;
      --border:    #2d3148;
      --border2:   #3b4163;
      --text:      #e2e8f0;
      --text-dim:  #64748b;
      --text-mid:  #94a3b8;
      --purple:    #7c3aed;
      --purple-lt: #a78bfa;
      --blue:      #60a5fa;
      --green:     #4ade80;
      --green-lt:  #86efac;
      --yellow:    #fbbf24;
      --red:       #f87171;
      --cyan:      #93c5fd;
      --lime:      #a3e635;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
      font-size: 13px;
    }

    /* ---- toolbar ---- */
    #toolbar {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 16px;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    #toolbar h1 {
      font-size: 13px;
      font-weight: 700;
      color: var(--purple-lt);
      white-space: nowrap;
    }
    .stats {
      font-size: 11px;
      color: var(--text-dim);
      white-space: nowrap;
    }
    .tb-sep { width: 1px; height: 18px; background: var(--border); flex-shrink: 0; }

    #search-box {
      flex: 1;
      min-width: 160px;
      max-width: 340px;
      padding: 5px 10px;
      border-radius: 6px;
      border: 1px solid var(--border2);
      background: var(--bg);
      color: var(--text);
      font-size: 12px;
      outline: none;
    }
    #search-box:focus { border-color: var(--purple); }
    #search-box::placeholder { color: var(--text-dim); }

    .tb-btn {
      padding: 4px 10px;
      background: var(--bg3);
      border: 1px solid var(--border2);
      color: var(--text-mid);
      font-size: 11px;
      border-radius: 5px;
      cursor: pointer;
      white-space: nowrap;
    }
    .tb-btn:hover { border-color: var(--purple); color: var(--text); }
    .tb-btn.active { background: #3b1fa8; border-color: var(--purple); color: #fff; }

    /* ---- main layout ---- */
    #main { display: flex; flex: 1; overflow: hidden; }

    /* ---- tree panel ---- */
    #tree-panel { flex: 1; overflow-y: auto; padding: 8px 0; min-width: 0; }
    #tree-panel.hidden { display: none; }

    /* ---- search results overlay ---- */
    #search-results { display: none; flex: 1; overflow-y: auto; padding: 8px 12px; }
    #search-results.visible { display: block; }

    /* ---- tree nodes ---- */
    .tree-item {
      display: flex;
      align-items: center;
      padding: 2px 0;
      padding-left: calc(var(--depth,0) * 16px + 8px);
      cursor: pointer;
      user-select: none;
      border-radius: 4px;
    }
    .tree-item:hover { background: var(--bg3); }
    .tree-item.selected { background: #2a1f5e; }

    .arrow {
      display: inline-flex; align-items: center; justify-content: center;
      width: 16px; height: 16px; flex-shrink: 0;
      font-size: 9px; color: var(--text-dim);
      transition: transform 0.12s ease;
    }
    .arrow.open { transform: rotate(90deg); }
    .arrow.leaf { color: transparent; pointer-events: none; }

    .kind-dot {
      width: 7px; height: 7px; border-radius: 50%;
      flex-shrink: 0; margin: 0 5px 0 2px;
    }
    .dot-folder    { background: var(--text-dim); }
    .dot-file      { background: var(--blue); border-radius: 2px; }
    .dot-class     { background: var(--purple-lt); }
    .dot-function  { background: var(--green); }
    .dot-method    { background: var(--green-lt); }
    .dot-interface { background: var(--cyan); }
    .dot-struct    { background: var(--yellow); }
    .dot-enum      { background: var(--red); }
    .dot-trait     { background: var(--lime); }
    .dot-external  { background: var(--text-dim); opacity: 0.4; }

    .node-label { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; }
    .node-label .node-name { color: var(--text); }
    .node-label.folder-label .node-name { color: var(--text-mid); }
    .node-label .node-suffix { font-size: 10px; color: var(--text-dim); margin-left: 4px; }
    .async-badge { font-size: 9px; color: var(--yellow); margin-left: 4px; flex-shrink: 0; }

    .tree-children { display: none; }
    .tree-children.open { display: block; }

    /* ---- detail panel ---- */
    #detail-panel {
      width: 380px; min-width: 280px; max-width: 520px;
      background: var(--bg2);
      border-left: 1px solid var(--border);
      display: flex; flex-direction: column; overflow: hidden;
      flex-shrink: 0;
      transition: width 0.15s ease;
    }
    #detail-panel.collapsed { width: 0; min-width: 0; border: none; }

    #detail-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 16px; border-bottom: 1px solid var(--border); flex-shrink: 0;
    }
    #detail-header h2 {
      font-size: 13px; font-weight: 600; color: var(--purple-lt);
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    #close-detail {
      background: none; border: none; color: var(--text-dim);
      font-size: 18px; cursor: pointer; padding: 0; line-height: 1; flex-shrink: 0;
    }
    #close-detail:hover { color: var(--text); }

    #detail-content { flex: 1; overflow-y: auto; padding: 14px 16px; font-size: 12px; line-height: 1.6; }

    .detail-empty { color: var(--text-dim); font-style: italic; text-align: center; margin-top: 40px; }
    .detail-field { margin-bottom: 12px; }
    .detail-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 3px; }
    .detail-value { color: var(--text); word-break: break-word; }

    .kind-badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .badge-folder    { background: #1e2235; color: var(--text-mid); }
    .badge-file      { background: #1e3a5f; color: var(--blue); }
    .badge-class     { background: #2d1b4e; color: var(--purple-lt); }
    .badge-function  { background: #1a3a2a; color: var(--green); }
    .badge-method    { background: #1a3a2a; color: var(--green-lt); }
    .badge-interface { background: #1f2d4a; color: var(--cyan); }
    .badge-struct    { background: #3a2a10; color: var(--yellow); }
    .badge-enum      { background: #3a1010; color: var(--red); }
    .badge-trait     { background: #2a3a10; color: var(--lime); }
    .badge-external  { background: #1e1e1e; color: var(--text-mid); }

    .detail-sig {
      font-family: 'SF Mono','Fira Code','Cascadia Code',monospace;
      font-size: 11px; background: var(--bg); padding: 7px 10px;
      border-radius: 4px; border-left: 3px solid var(--purple);
      white-space: pre-wrap; word-break: break-all;
    }
    .detail-doc { font-style: italic; color: var(--text-mid); font-size: 11px; line-height: 1.6; }

    /* ---- search results ---- */
    .search-result-item {
      padding: 5px 8px; border-radius: 4px; cursor: pointer;
      display: flex; align-items: center; gap: 6px;
    }
    .search-result-item:hover { background: var(--bg3); }
    .search-result-item .sr-name { font-size: 12px; color: var(--text); font-weight: 500; }
    .search-result-item .sr-path { font-size: 10px; color: var(--text-dim); margin-left: 4px; }
    .search-empty { color: var(--text-dim); font-style: italic; padding: 20px; text-align: center; }

    /* ---- scrollbar ---- */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--border2); }
  </style>
</head>
<body>

<div id="toolbar">
  <h1>&#9670; graphmy &mdash; {{ project_name }}</h1>
  <span class="stats">
    {{ file_count }} files &middot; {{ node_count }} symbols &middot; {{ edge_count }} edges &middot; {{ generated_at }}
  </span>
  <div class="tb-sep"></div>
  <input id="search-box" type="text" placeholder="Search symbols&hellip;" autocomplete="off" />
  <div class="tb-sep"></div>
  <button class="tb-btn active" id="btn-expand-all"   onclick="expandAll()">Expand All</button>
  <button class="tb-btn"        id="btn-collapse-all" onclick="collapseAll()">Collapse All</button>
</div>

<div id="main">
  <div id="tree-panel"></div>
  <div id="search-results"></div>

  <div id="detail-panel" class="collapsed">
    <div id="detail-header">
      <h2 id="detail-title">Symbol detail</h2>
      <button id="close-detail" onclick="closeDetail()" title="Close">&times;</button>
    </div>
    <div id="detail-content">
      <p class="detail-empty">Click any symbol to see details.</p>
    </div>
  </div>
</div>

<!-- data blobs -->
<script type="application/json" id="tree-data">{{ tree_json }}</script>
<script type="application/json" id="detail-data">{{ detail_json }}</script>
<script type="application/json" id="all-nodes-data">{{ all_nodes_json }}</script>

<script>
"use strict";

// ── 1. load data ──────────────────────────────────────────────────────────
const TREE      = JSON.parse(document.getElementById('tree-data').textContent);
const DETAIL    = JSON.parse(document.getElementById('detail-data').textContent);
const ALL_NODES = JSON.parse(document.getElementById('all-nodes-data').textContent);

// id → slim tree node (for search navigation)
const NODE_BY_ID = {};
(function index(nodes) {
  for (const n of nodes) {
    NODE_BY_ID[n.id] = n;
    if (n.children && n.children.length) index(n.children);
  }
})(TREE);

// ── 2. render tree ────────────────────────────────────────────────────────
const treePanel = document.getElementById('tree-panel');

function renderTree(nodes, depth, container) {
  for (const node of nodes) {
    const hasKids = node.children && node.children.length > 0;
    const wrapper  = document.createElement('div');

    const row = document.createElement('div');
    row.className = 'tree-item';
    row.style.setProperty('--depth', depth);
    row.dataset.id   = node.id;
    row.dataset.kind = node.kind;

    // arrow
    const arrow = document.createElement('span');
    arrow.className = 'arrow' + (hasKids ? '' : ' leaf');
    arrow.textContent = hasKids ? '▶' : '';
    row.appendChild(arrow);

    // dot
    const dot = document.createElement('span');
    dot.className = 'kind-dot dot-' + (node.kind || 'external');
    row.appendChild(dot);

    // label
    const label = document.createElement('span');
    label.className = 'node-label' + (node.kind === 'folder' ? ' folder-label' : '');

    const nameSpan = document.createElement('span');
    nameSpan.className = 'node-name';
    nameSpan.textContent = node.name;
    label.appendChild(nameSpan);

    if (node.kind === 'file' && node.language) {
      const suf = document.createElement('span');
      suf.className = 'node-suffix';
      suf.textContent = node.language;
      label.appendChild(suf);
    } else if ((node.kind === 'method' || node.kind === 'function') && node.line) {
      const suf = document.createElement('span');
      suf.className = 'node-suffix';
      suf.textContent = ':' + node.line;
      label.appendChild(suf);
    }
    row.appendChild(label);

    if (node.is_async) {
      const badge = document.createElement('span');
      badge.className = 'async-badge';
      badge.textContent = 'async';
      row.appendChild(badge);
    }

    const childrenDiv = document.createElement('div');
    childrenDiv.className = 'tree-children';

    if (hasKids) {
      row.addEventListener('click', function(e) {
        const open = childrenDiv.classList.contains('open');
        childrenDiv.classList.toggle('open', !open);
        arrow.classList.toggle('open', !open);
        selectNode(row, node);
        e.stopPropagation();
      });
      renderTree(node.children, depth + 1, childrenDiv);
    } else {
      row.addEventListener('click', function(e) {
        selectNode(row, node);
        e.stopPropagation();
      });
    }

    wrapper.appendChild(row);
    wrapper.appendChild(childrenDiv);
    container.appendChild(wrapper);
  }
}

renderTree(TREE, 0, treePanel);

// ── 3. selection + detail panel ───────────────────────────────────────────
let selectedRow = null;

function selectNode(row, node) {
  if (selectedRow) selectedRow.classList.remove('selected');
  row.classList.add('selected');
  selectedRow = row;
  showDetail(node);
}

function showDetail(node) {
  const panel   = document.getElementById('detail-panel');
  const content = document.getElementById('detail-content');
  const title   = document.getElementById('detail-title');

  panel.classList.remove('collapsed');
  title.textContent = node.name;

  // Look up richer fields from DETAIL map.
  const d = DETAIL[node.id] || {};

  let html = '';

  // kind badge + language + async
  html += '<div class="detail-field"><div class="detail-label">Kind</div>'
        + '<div class="detail-value">'
        + '<span class="kind-badge badge-' + esc(node.kind || 'external') + '">'
        + esc(node.kind || 'unknown') + '</span>';
  if (node.language) html += ' <span style="color:var(--text-dim);font-size:11px">' + esc(node.language) + '</span>';
  if (node.is_async) html += ' <span style="color:var(--yellow);font-size:11px">async</span>';
  html += '</div></div>';

  // location (file:start–end)
  const loc = node.line ? node.file + ':' + node.line + (d.end_line ? '–' + d.end_line : '') : node.file;
  if (loc) {
    html += '<div class="detail-field"><div class="detail-label">Location</div>'
          + '<div class="detail-value" style="font-family:monospace;font-size:11px;color:var(--text-mid)">'
          + esc(loc) + '</div></div>';
  }

  // contains summary (e.g. "3 methods, 1 function")
  if (d.children_summary) {
    html += '<div class="detail-field"><div class="detail-label">Contains</div>'
          + '<div class="detail-value" style="color:var(--text-mid);font-size:11px">'
          + esc(d.children_summary) + '</div></div>';
  }

  // hint to use --serve for full detail
  html += '<div style="margin-top:20px;font-size:10px;color:var(--text-dim)">'
        + 'Run <code style="color:var(--purple-lt)">graphmy serve &lt;path&gt;</code> for signatures, docstrings &amp; source.'
        + '</div>';

  content.innerHTML = html;
}

function closeDetail() {
  document.getElementById('detail-panel').classList.add('collapsed');
  if (selectedRow) { selectedRow.classList.remove('selected'); selectedRow = null; }
}

// ── 4. expand / collapse all ──────────────────────────────────────────────
function expandAll() {
  treePanel.querySelectorAll('.tree-children').forEach(el => el.classList.add('open'));
  treePanel.querySelectorAll('.arrow:not(.leaf)').forEach(el => el.classList.add('open'));
  document.getElementById('btn-expand-all').classList.add('active');
  document.getElementById('btn-collapse-all').classList.remove('active');
}
function collapseAll() {
  treePanel.querySelectorAll('.tree-children').forEach(el => el.classList.remove('open'));
  treePanel.querySelectorAll('.arrow:not(.leaf)').forEach(el => el.classList.remove('open'));
  document.getElementById('btn-collapse-all').classList.add('active');
  document.getElementById('btn-expand-all').classList.remove('active');
}

// ── 5. search ─────────────────────────────────────────────────────────────
const searchBox     = document.getElementById('search-box');
const searchResults = document.getElementById('search-results');

searchBox.addEventListener('input', function() {
  const q = this.value.trim().toLowerCase();
  q ? runSearch(q) : clearSearch();
});
searchBox.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') { this.value = ''; clearSearch(); }
});

function clearSearch() {
  searchResults.innerHTML = '';
  searchResults.classList.remove('visible');
  treePanel.classList.remove('hidden');
}

function runSearch(q) {
  const matches = ALL_NODES.filter(n =>
    n.name.toLowerCase().includes(q) ||
    (n.file && n.file.toLowerCase().includes(q))
  ).slice(0, 100);

  treePanel.classList.add('hidden');
  searchResults.classList.add('visible');

  if (!matches.length) {
    searchResults.innerHTML = '<p class="search-empty">No symbols match "' + esc(q) + '"</p>';
    return;
  }

  const frag = document.createDocumentFragment();
  if (matches.length === 100) {
    const note = document.createElement('p');
    note.style.cssText = 'font-size:10px;color:var(--text-dim);padding:4px 8px';
    note.textContent = 'Showing first 100 — type more to narrow down.';
    frag.appendChild(note);
  }
  for (const m of matches) {
    const row = document.createElement('div');
    row.className = 'search-result-item';
    row.innerHTML =
      '<span class="kind-dot dot-' + (m.kind||'external') + '"></span>'
      + '<span class="sr-name">' + esc(m.name) + '</span>'
      + '<span class="sr-path">' + esc(m.file || '') + (m.line ? ':' + m.line : '') + '</span>';
    row.addEventListener('click', function() {
      const node = NODE_BY_ID[m.id];
      if (node) showDetail(node);
      searchBox.value = '';
      clearSearch();
      revealInTree(m.id);
    });
    frag.appendChild(row);
  }
  searchResults.innerHTML = '';
  searchResults.appendChild(frag);
}

function revealInTree(nodeId) {
  const row = treePanel.querySelector('[data-id="' + CSS.escape(nodeId) + '"]');
  if (!row) return;
  let el = row.parentElement;
  while (el && el !== treePanel) {
    if (el.classList.contains('tree-children')) {
      el.classList.add('open');
      const prev = el.previousElementSibling;
      if (prev) { const a = prev.querySelector('.arrow'); if (a) a.classList.add('open'); }
    }
    el = el.parentElement;
  }
  row.scrollIntoView({ block: 'center', behavior: 'smooth' });
  row.classList.add('selected');
  selectedRow = row;
}

// ── 6. utility ────────────────────────────────────────────────────────────
function esc(str) {
  if (typeof str !== 'string') str = String(str ?? '');
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
            .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}
</script>
</body>
</html>
