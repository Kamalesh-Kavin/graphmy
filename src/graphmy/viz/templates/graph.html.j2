<!DOCTYPE html>
{#
  graphmy/viz/templates/graph.html.j2
  =====================================
  Self-contained HTML visualisation for a graphmy knowledge graph.

  This file is rendered by Jinja2 (_template.py) and produces a single
  .html file with NO external dependencies beyond CDN scripts.

  Template variables (all passed from _template.py):
    graph_data_json : str  — JSON string {"nodes": [...], "edges": [...]} (no body fields)
    bodies_json     : str  — JSON string {node_id: body_string, ...} loaded on-demand
    project_name    : str  — display name for the project
    node_count      : int  — total number of nodes in the graph
    edge_count      : int  — total number of edges in the graph
    generated_at    : str  — timestamp string
    serve_mode      : bool — True when rendered by _server.py (enables NL query bar)
    graphmy_version : str  — e.g. "0.1.1"

  Performance strategy for large codebases:
    - body fields are NOT inlined into the main graph data; loaded from BODY_DATA on click
    - External nodes (kind=external) are hidden by default via a CSS class toggle
    - Initial render shows only CONTAINS + DEFINES edges (structural skeleton)
    - CALLS / IMPORTS / INHERITS / IMPLEMENTS edges toggled via toolbar buttons
    - Graphs with >500 nodes default to the 'cose' (force-directed) layout;
      dagre is offered as a manual switch but warned as slow for large graphs
#}
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>graphmy — {{ project_name }}</title>

  {# Load cytoscape.js and cytoscape-dagre from CDN #}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cytoscape/3.28.1/cytoscape.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/dagre/0.8.5/dagre.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/cytoscape-dagre@2.5.0/cytoscape-dagre.js"></script>

  <style>
    /* -----------------------------------------------------------------------
       Reset & base
    ----------------------------------------------------------------------- */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, monospace;
      background: #0f1117;
      color: #e2e8f0;
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    /* -----------------------------------------------------------------------
       Toolbar (top bar)
    ----------------------------------------------------------------------- */
    #toolbar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      background: #1a1d2e;
      border-bottom: 1px solid #2d3148;
      flex-shrink: 0;
      flex-wrap: wrap;
    }
    #toolbar h1 {
      font-size: 13px;
      font-weight: 600;
      color: #a78bfa;
      white-space: nowrap;
    }
    #toolbar .stats {
      font-size: 11px;
      color: #64748b;
      white-space: nowrap;
    }
    #search-box {
      flex: 1;
      min-width: 160px;
      max-width: 320px;
      padding: 4px 9px;
      border-radius: 6px;
      border: 1px solid #3b4163;
      background: #0f1117;
      color: #e2e8f0;
      font-size: 12px;
      outline: none;
    }
    #search-box:focus { border-color: #7c3aed; }
    #search-box::placeholder { color: #475569; }

    /* NL query bar (only visible in serve mode) */
    #nl-bar {
      display: {% if serve_mode %}flex{% else %}none{% endif %};
      align-items: center;
      gap: 8px;
      flex: 1;
      min-width: 280px;
    }
    #nl-input {
      flex: 1;
      padding: 4px 9px;
      border-radius: 6px;
      border: 1px solid #3b4163;
      background: #0f1117;
      color: #e2e8f0;
      font-size: 12px;
      outline: none;
    }
    #nl-input:focus { border-color: #7c3aed; }
    #nl-input::placeholder { color: #475569; }

    button {
      padding: 4px 11px;
      border-radius: 6px;
      border: none;
      background: #7c3aed;
      color: white;
      font-size: 11px;
      cursor: pointer;
      white-space: nowrap;
    }
    button:hover { background: #6d28d9; }
    button:disabled { background: #374151; cursor: not-allowed; }

    /* Layout + edge toggle buttons */
    .tb-btn {
      padding: 3px 9px;
      background: #1e2235;
      border: 1px solid #3b4163;
      color: #94a3b8;
      font-size: 11px;
      border-radius: 5px;
      cursor: pointer;
    }
    .tb-btn:hover { border-color: #7c3aed; color: #e2e8f0; background: #1e2235; }
    .tb-btn.active { background: #3b1fa8; border-color: #7c3aed; color: white; }

    /* Divider between toolbar button groups */
    .tb-sep {
      width: 1px;
      height: 18px;
      background: #2d3148;
      flex-shrink: 0;
    }

    /* -----------------------------------------------------------------------
       Main canvas area
    ----------------------------------------------------------------------- */
    #main {
      display: flex;
      flex: 1;
      overflow: hidden;
    }
    #cy {
      flex: 1;
      background: #0f1117;
      background-image: radial-gradient(circle, #1e2235 1px, transparent 1px);
      background-size: 24px 24px;
    }

    /* -----------------------------------------------------------------------
       Detail panel (right sidebar)
    ----------------------------------------------------------------------- */
    #detail-panel {
      width: 360px;
      min-width: 280px;
      max-width: 480px;
      background: #1a1d2e;
      border-left: 1px solid #2d3148;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: width 0.2s ease;
    }
    #detail-panel.collapsed { width: 0; min-width: 0; border: none; }
    #detail-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 9px 14px;
      border-bottom: 1px solid #2d3148;
      flex-shrink: 0;
    }
    #detail-header h2 { font-size: 13px; font-weight: 600; color: #a78bfa; }
    #close-detail {
      background: none;
      border: none;
      color: #64748b;
      font-size: 16px;
      cursor: pointer;
      padding: 0;
    }
    #close-detail:hover { color: #e2e8f0; background: none; }
    #detail-content {
      flex: 1;
      overflow-y: auto;
      padding: 12px 14px;
      font-size: 12px;
      line-height: 1.6;
    }
    .detail-empty {
      color: #475569;
      font-style: italic;
      margin-top: 20px;
      text-align: center;
    }
    .detail-field { margin-bottom: 10px; }
    .detail-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #64748b;
      margin-bottom: 2px;
    }
    .detail-value { color: #e2e8f0; word-break: break-all; }
    .kind-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
    }
    .badge-file       { background: #1e3a5f; color: #60a5fa; }
    .badge-class      { background: #2d1b4e; color: #c084fc; }
    .badge-function   { background: #1a3a2a; color: #4ade80; }
    .badge-method     { background: #1a3a2a; color: #86efac; }
    .badge-interface  { background: #1f2d4a; color: #93c5fd; }
    .badge-struct     { background: #3a2a10; color: #fbbf24; }
    .badge-enum       { background: #3a1010; color: #f87171; }
    .badge-trait      { background: #2a3a10; color: #a3e635; }
    .badge-external   { background: #1e1e1e; color: #94a3b8; }

    .detail-sig {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 11px;
      background: #0f1117;
      padding: 6px 8px;
      border-radius: 4px;
      border-left: 3px solid #7c3aed;
      word-break: break-all;
      white-space: pre-wrap;
    }
    .detail-doc {
      font-style: italic;
      color: #94a3b8;
      font-size: 11px;
      line-height: 1.5;
    }
    .caller-callee-list { list-style: none; }
    .caller-callee-list li {
      font-size: 11px;
      padding: 2px 0;
      color: #a78bfa;
      cursor: pointer;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .caller-callee-list li:hover { color: #c4b5fd; text-decoration: underline; }

    pre.source-preview {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 10px;
      line-height: 1.4;
      background: #0a0d14;
      padding: 8px;
      border-radius: 4px;
      overflow: auto;
      max-height: 280px;
      color: #94a3b8;
      white-space: pre;
      border: 1px solid #1e2235;
    }

    /* -----------------------------------------------------------------------
       Legend (bottom-left overlay)
    ----------------------------------------------------------------------- */
    #legend {
      position: absolute;
      bottom: 12px;
      left: 12px;
      background: rgba(26, 29, 46, 0.92);
      border: 1px solid #2d3148;
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 11px;
      pointer-events: none;
    }
    .legend-row { display: flex; align-items: center; gap: 6px; margin: 2px 0; }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

    /* -----------------------------------------------------------------------
       Large-graph warning banner
    ----------------------------------------------------------------------- */
    #large-graph-warning {
      display: none;
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      background: #3a2a10;
      border: 1px solid #fbbf24;
      border-radius: 6px;
      padding: 6px 16px;
      font-size: 12px;
      color: #fbbf24;
      z-index: 50;
      pointer-events: none;
    }

    /* -----------------------------------------------------------------------
       NL explanation overlay
    ----------------------------------------------------------------------- */
    #nl-explanation {
      display: none;
      position: absolute;
      top: 60px;
      left: 50%;
      transform: translateX(-50%);
      max-width: 600px;
      width: calc(100% - 40px);
      background: #1a1d2e;
      border: 1px solid #3b4163;
      border-radius: 8px;
      padding: 14px 18px;
      font-size: 13px;
      color: #e2e8f0;
      z-index: 100;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    }
    #nl-explanation .close-explain {
      position: absolute; top: 8px; right: 12px;
      background: none; border: none; color: #64748b;
      font-size: 18px; cursor: pointer; padding: 0;
    }
    #nl-explanation .close-explain:hover { color: white; background: none; }
    #nl-explanation p { line-height: 1.7; }

    /* -----------------------------------------------------------------------
       Loading spinner overlay
    ----------------------------------------------------------------------- */
    #loading {
      display: none;
      position: absolute;
      inset: 0;
      background: rgba(15, 17, 23, 0.7);
      align-items: center;
      justify-content: center;
      z-index: 200;
      font-size: 14px;
      color: #a78bfa;
    }
    #loading.visible { display: flex; }

    /* -----------------------------------------------------------------------
       Scrollbar styling
    ----------------------------------------------------------------------- */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #0f1117; }
    ::-webkit-scrollbar-thumb { background: #2d3148; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #3b4163; }
  </style>
</head>
<body>

<!-- =========================================================================
     Toolbar
========================================================================= -->
<div id="toolbar">
  <h1>&#9670; graphmy &mdash; {{ project_name }}</h1>
  <span class="stats">{{ node_count }} nodes &middot; {{ edge_count }} edges &middot; {{ generated_at }}</span>

  <div class="tb-sep"></div>

  <!-- Fuzzy search -->
  <input id="search-box" type="text" placeholder="Filter by name&hellip;" autocomplete="off" />

  <div class="tb-sep"></div>

  <!-- Layout toggles -->
  <span style="font-size:10px;color:#64748b;white-space:nowrap">Layout:</span>
  <button class="tb-btn" id="btn-dagre"  onclick="setLayout('dagre')">Hierarchy</button>
  <button class="tb-btn" id="btn-cose"   onclick="setLayout('cose')">Force</button>
  <button class="tb-btn" id="btn-circle" onclick="setLayout('circle')">Circle</button>

  <div class="tb-sep"></div>

  <!-- Edge type toggles -->
  <span style="font-size:10px;color:#64748b;white-space:nowrap">Edges:</span>
  <button class="tb-btn active" id="edge-CONTAINS"   onclick="toggleEdge('CONTAINS')">Contains</button>
  <button class="tb-btn active" id="edge-DEFINES"    onclick="toggleEdge('DEFINES')">Defines</button>
  <button class="tb-btn"        id="edge-CALLS"      onclick="toggleEdge('CALLS')">Calls</button>
  <button class="tb-btn"        id="edge-IMPORTS"    onclick="toggleEdge('IMPORTS')">Imports</button>
  <button class="tb-btn"        id="edge-INHERITS"   onclick="toggleEdge('INHERITS')">Inherits</button>
  <button class="tb-btn"        id="edge-IMPLEMENTS" onclick="toggleEdge('IMPLEMENTS')">Implements</button>

  <div class="tb-sep"></div>

  <!-- External nodes toggle -->
  <button class="tb-btn" id="btn-external" onclick="toggleExternal()">Show External</button>

  <!-- NL query bar (only in --serve mode) -->
  <div id="nl-bar">
    <input id="nl-input" type="text" placeholder="Ask anything about the codebase&hellip;" autocomplete="off" />
    <button id="nl-search-btn" onclick="runNLQuery()">Search</button>
    {% if serve_mode %}
    <button id="nl-explain-btn" onclick="runNLQuery(true)">Explain</button>
    {% endif %}
  </div>
</div>

<!-- =========================================================================
     Main area: graph canvas + detail panel
========================================================================= -->
<div id="main">
  <div id="cy"></div>

  <!-- Detail panel (right sidebar) -->
  <div id="detail-panel" class="collapsed">
    <div id="detail-header">
      <h2 id="detail-title">Symbol detail</h2>
      <button id="close-detail" onclick="closeDetail()" title="Close">&times;</button>
    </div>
    <div id="detail-content">
      <p class="detail-empty">Click a node to see details.</p>
    </div>
  </div>
</div>

<!-- Legend -->
<div id="legend">
  <div class="legend-row"><div class="legend-dot" style="background:#60a5fa"></div> file</div>
  <div class="legend-row"><div class="legend-dot" style="background:#c084fc"></div> class</div>
  <div class="legend-row"><div class="legend-dot" style="background:#4ade80"></div> function</div>
  <div class="legend-row"><div class="legend-dot" style="background:#86efac"></div> method</div>
  <div class="legend-row"><div class="legend-dot" style="background:#93c5fd"></div> interface</div>
  <div class="legend-row"><div class="legend-dot" style="background:#fbbf24"></div> struct/enum</div>
  <div class="legend-row"><div class="legend-dot" style="background:#94a3b8;border:1px dashed #475569"></div> external</div>
</div>

<!-- Large graph warning (shown when >2000 nodes) -->
<div id="large-graph-warning">
  Large graph (&gt;2000 nodes) &mdash; use edge toggles and the search box to focus.
</div>

<!-- NL explanation overlay -->
<div id="nl-explanation">
  <button class="close-explain" onclick="closeExplanation()">&times;</button>
  <p id="explanation-text"></p>
</div>

<!-- Loading overlay -->
<div id="loading"><span>Rendering graph&hellip;</span></div>

<!-- =========================================================================
     Inline graph data (injected by Jinja2)
     Split into two blobs:
       graph-data : nodes (no body) + edges
       body-data  : { node_id: body_string } loaded only on node click
========================================================================= -->
<script type="application/json" id="graph-data">
{{ graph_data_json }}
</script>
<script type="application/json" id="body-data">
{{ bodies_json }}
</script>

<!-- =========================================================================
     Main script
========================================================================= -->
<script>
"use strict";

// ---------------------------------------------------------------------------
// 1. Register cytoscape-dagre layout extension
// ---------------------------------------------------------------------------
if (typeof cytoscapeDagre !== 'undefined') {
  cytoscape.use(cytoscapeDagre);
}

// ---------------------------------------------------------------------------
// 2. Load the graph data injected by Jinja2
// ---------------------------------------------------------------------------
const rawData  = JSON.parse(document.getElementById('graph-data').textContent);
// BODY_DATA is a flat { node_id: body_string } map — loaded only when needed.
const BODY_DATA = JSON.parse(document.getElementById('body-data').textContent);

const TOTAL_NODES = rawData.nodes.length;
const TOTAL_EDGES = rawData.edges.length;

// Large graph threshold — above this, hide CALLS/IMPORTS edges by default
// and switch to cose layout to avoid dagre OOM.
const LARGE_GRAPH_THRESHOLD = 500;
const isLarge = TOTAL_NODES > LARGE_GRAPH_THRESHOLD;

// Edge kinds visible on initial load.
// For large graphs we start with structural edges only (CONTAINS, DEFINES).
// User can toggle others via the toolbar buttons.
const visibleEdgeKinds = new Set(
  isLarge
    ? ['CONTAINS', 'DEFINES']
    : ['CONTAINS', 'DEFINES', 'CALLS', 'IMPORTS', 'INHERITS', 'IMPLEMENTS']
);

// External nodes hidden by default (they add noise for large graphs).
let showExternal = false;

// ---------------------------------------------------------------------------
// 3. Build the initial elements array respecting visibility rules
// ---------------------------------------------------------------------------
function buildElements() {
  // Nodes: filter external nodes if showExternal is false.
  const nodes = rawData.nodes.filter(n =>
    showExternal || n.data.kind !== 'external'
  );
  const visibleNodeIds = new Set(nodes.map(n => n.data.id));

  // Edges: filter by visible kind AND require both endpoints to be visible.
  const edges = rawData.edges.filter(e =>
    visibleEdgeKinds.has(e.data.kind) &&
    visibleNodeIds.has(e.data.source) &&
    visibleNodeIds.has(e.data.target)
  );

  return [...nodes, ...edges];
}

// ---------------------------------------------------------------------------
// 4. Colour map by node kind
// ---------------------------------------------------------------------------
const KIND_COLORS = {
  'file':       '#60a5fa',
  'class':      '#c084fc',
  'function':   '#4ade80',
  'method':     '#86efac',
  'interface':  '#93c5fd',
  'struct':     '#fbbf24',
  'enum':       '#f87171',
  'trait':      '#a3e635',
  'external':   '#475569',
};

// ---------------------------------------------------------------------------
// 5. Cytoscape style sheet
// ---------------------------------------------------------------------------
const CY_STYLE = [
  {
    selector: 'node',
    style: {
      'label': 'data(label)',
      'font-size': '10px',
      'color': '#e2e8f0',
      'text-valign': 'bottom',
      'text-halign': 'center',
      'text-margin-y': '4px',
      'background-color': function(ele) {
        return KIND_COLORS[ele.data('kind')] || '#475569';
      },
      'width': function(ele) {
        const deg = ele.degree(false);
        return Math.min(6 + deg * 1.5, 22);
      },
      'height': function(ele) {
        const deg = ele.degree(false);
        return Math.min(6 + deg * 1.5, 22);
      },
      'border-width': 0,
      'transition-property': 'background-color, border-width, opacity',
      'transition-duration': '0.15s',
    }
  },
  {
    selector: 'node.kind-file',
    style: { 'shape': 'diamond', 'width': 14, 'height': 14 }
  },
  {
    selector: 'node.kind-external',
    style: {
      'background-color': 'transparent',
      'border-width': 1,
      'border-style': 'dashed',
      'border-color': '#475569',
      'width': 8, 'height': 8,
      'opacity': 0.5,
    }
  },
  {
    selector: 'node:selected',
    style: {
      'border-width': 2,
      'border-color': '#a78bfa',
      'background-color': function(ele) {
        return KIND_COLORS[ele.data('kind')] || '#7c3aed';
      },
    }
  },
  {
    selector: 'node.highlighted',
    style: { 'border-width': 2, 'border-color': '#fbbf24', 'opacity': 1 }
  },
  {
    selector: 'node.dimmed',
    style: { 'opacity': 0.12 }
  },
  {
    selector: 'edge',
    style: {
      'width': 1,
      'line-color': '#2d3148',
      'target-arrow-color': '#2d3148',
      'target-arrow-shape': 'triangle',
      'curve-style': 'bezier',
      'opacity': 0.6,
    }
  },
  {
    selector: 'edge[kind = "CALLS"]',
    style: { 'line-color': '#4ade80', 'target-arrow-color': '#4ade80', 'width': 1.5 }
  },
  {
    selector: 'edge[kind = "IMPORTS"]',
    style: { 'line-color': '#60a5fa', 'target-arrow-color': '#60a5fa', 'line-style': 'dashed' }
  },
  {
    selector: 'edge[kind = "INHERITS"]',
    style: { 'line-color': '#c084fc', 'target-arrow-color': '#c084fc', 'width': 2 }
  },
  {
    selector: 'edge[kind = "IMPLEMENTS"]',
    style: { 'line-color': '#93c5fd', 'target-arrow-color': '#93c5fd', 'line-style': 'dotted' }
  },
  {
    selector: 'edge[kind = "DEFINES"]',
    style: { 'line-color': '#334155', 'target-arrow-color': '#334155', 'opacity': 0.35 }
  },
  {
    selector: 'edge[kind = "CONTAINS"]',
    style: { 'line-color': '#334155', 'target-arrow-color': '#334155', 'opacity': 0.35 }
  },
  {
    selector: 'edge:selected',
    style: { 'line-color': '#a78bfa', 'target-arrow-color': '#a78bfa', 'width': 2 }
  },
];

// ---------------------------------------------------------------------------
// 6. Choose initial layout based on graph size
// ---------------------------------------------------------------------------
// dagre is fast for small graphs but can OOM / hang on dense large ones.
// cose (force-directed) scales much better for thousands of nodes.
const initialLayout = isLarge
  ? { name: 'cose', idealEdgeLength: 80, nodeRepulsion: 4000, padding: 20, animate: false }
  : { name: 'dagre', rankDir: 'TB', nodeSep: 30, rankSep: 60, padding: 20 };

let currentLayout = isLarge ? 'cose' : 'dagre';

// ---------------------------------------------------------------------------
// 7. Initialise cytoscape
// ---------------------------------------------------------------------------
const cy = cytoscape({
  container: document.getElementById('cy'),
  elements: buildElements(),
  style: CY_STYLE,
  layout: initialLayout,
  wheelSensitivity: 0.3,
  // Disable labels on edges for performance
  textureOnViewport: isLarge,
  hideEdgesOnViewport: isLarge,
});

// Mark the active layout button
document.getElementById('btn-' + currentLayout).classList.add('active');

// Sync edge toggle button states for large graphs (CALLS/IMPORTS start off)
if (isLarge) {
  ['CALLS', 'IMPORTS', 'INHERITS', 'IMPLEMENTS'].forEach(k => {
    const btn = document.getElementById('edge-' + k);
    if (btn) btn.classList.remove('active');
  });
  document.getElementById('large-graph-warning').style.display = 'block';
}

// ---------------------------------------------------------------------------
// 8. Node click → detail panel
// ---------------------------------------------------------------------------
cy.on('tap', 'node', function(evt) {
  showDetail(evt.target.data(), evt.target.id());
});

cy.on('tap', function(evt) {
  if (evt.target === cy) {
    clearHighlights();
    closeDetail();
  }
});

// ---------------------------------------------------------------------------
// 9. Detail panel
// ---------------------------------------------------------------------------
function showDetail(data, nodeId) {
  const panel   = document.getElementById('detail-panel');
  const content = document.getElementById('detail-content');
  const title   = document.getElementById('detail-title');

  panel.classList.remove('collapsed');
  title.textContent = data.label || data.id;

  const badgeClass = 'badge-' + (data.kind || 'external');
  const loc = data.line ? (data.file + ':' + data.line) : (data.file || '');

  // Build caller / callee lists from CALLS edges currently loaded in cy.
  const nodeEle = cy.getElementById(nodeId);
  const callerItems = nodeEle.incomers('edge[kind = "CALLS"]').sources()
    .map(n => '<li onclick="focusNode(\'' + escHtml(n.id()) + '\')" title="' + escHtml(n.id()) + '">' + escHtml(n.data('label')) + '</li>')
    .join('');
  const calleeItems = nodeEle.outgoers('edge[kind = "CALLS"]').targets()
    .map(n => '<li onclick="focusNode(\'' + escHtml(n.id()) + '\')" title="' + escHtml(n.id()) + '">' + escHtml(n.data('label')) + '</li>')
    .join('');

  let html = '<div class="detail-field">'
    + '<div class="detail-label">Kind</div>'
    + '<div class="detail-value">'
    + '<span class="kind-badge ' + badgeClass + '">' + escHtml(data.kind || 'unknown') + '</span>'
    + (data.language ? '<span style="margin-left:6px;color:#64748b;font-size:11px">' + escHtml(data.language) + '</span>' : '')
    + (data.is_async ? '<span style="margin-left:6px;color:#fbbf24;font-size:11px">async</span>' : '')
    + '</div></div>';

  if (loc) {
    html += '<div class="detail-field"><div class="detail-label">Location</div>'
      + '<div class="detail-value" style="font-family:monospace;font-size:11px;color:#94a3b8">' + escHtml(loc) + '</div></div>';
  }

  if (data.signature) {
    html += '<div class="detail-field"><div class="detail-label">Signature</div>'
      + '<div class="detail-sig">' + escHtml(data.signature) + '</div></div>';
  }

  if (data.docstring) {
    html += '<div class="detail-field"><div class="detail-label">Docstring</div>'
      + '<div class="detail-doc">' + escHtml(data.docstring) + '</div></div>';
  }

  if (data.decorators && data.decorators.length > 0) {
    html += '<div class="detail-field"><div class="detail-label">Decorators</div>'
      + '<div class="detail-value" style="font-family:monospace;font-size:11px;color:#fbbf24">'
      + escHtml(data.decorators.join(', ')) + '</div></div>';
  }

  if (callerItems) {
    html += '<div class="detail-field"><div class="detail-label">Called by</div>'
      + '<ul class="caller-callee-list">' + callerItems + '</ul></div>';
  }

  if (calleeItems) {
    html += '<div class="detail-field"><div class="detail-label">Calls</div>'
      + '<ul class="caller-callee-list">' + calleeItems + '</ul></div>';
  }

  // Body: loaded on-demand from BODY_DATA — never part of the cy node payload.
  const body = BODY_DATA[nodeId];
  if (body && body.trim()) {
    html += '<div class="detail-field"><div class="detail-label">Source preview</div>'
      + '<pre class="source-preview">' + escHtml(body) + '</pre></div>';
  }

  content.innerHTML = html;
}

function closeDetail() {
  document.getElementById('detail-panel').classList.add('collapsed');
}

function focusNode(nodeId) {
  const ele = cy.getElementById(nodeId);
  if (ele.length) {
    cy.animate({ fit: { eles: ele, padding: 60 } }, { duration: 300 });
    ele.select();
    showDetail(ele.data(), nodeId);
  }
}

// ---------------------------------------------------------------------------
// 10. Fuzzy search (filter by name)
// ---------------------------------------------------------------------------
document.getElementById('search-box').addEventListener('input', function() {
  const query = this.value.trim().toLowerCase();
  if (!query) { clearHighlights(); return; }
  const matches = cy.nodes().filter(n => n.data('label').toLowerCase().includes(query));
  applyHighlight(matches);
});

function applyHighlight(matchNodes) {
  if (matchNodes.length === 0) { clearHighlights(); return; }
  cy.nodes().addClass('dimmed').removeClass('highlighted');
  cy.edges().style('opacity', 0.08);
  matchNodes.removeClass('dimmed').addClass('highlighted');
  matchNodes.neighborhood('node').removeClass('dimmed');
}

function clearHighlights() {
  cy.nodes().removeClass('dimmed').removeClass('highlighted');
  cy.edges().style('opacity', 0.6);
}

// ---------------------------------------------------------------------------
// 11. Edge type toggling
// ---------------------------------------------------------------------------
function toggleEdge(kind) {
  const btn = document.getElementById('edge-' + kind);
  if (visibleEdgeKinds.has(kind)) {
    visibleEdgeKinds.delete(kind);
    btn.classList.remove('active');
  } else {
    visibleEdgeKinds.add(kind);
    btn.classList.add('active');
  }
  refreshGraph();
}

// ---------------------------------------------------------------------------
// 12. External node toggling
// ---------------------------------------------------------------------------
function toggleExternal() {
  showExternal = !showExternal;
  const btn = document.getElementById('btn-external');
  btn.classList.toggle('active', showExternal);
  btn.textContent = showExternal ? 'Hide External' : 'Show External';
  refreshGraph();
}

// ---------------------------------------------------------------------------
// 13. Re-render the graph after edge/node visibility changes
// ---------------------------------------------------------------------------
function refreshGraph() {
  // Preserve viewport position so the user doesn't get disoriented.
  const pan  = cy.pan();
  const zoom = cy.zoom();

  cy.elements().remove();
  cy.add(buildElements());

  // Restore viewport — don't re-run layout (that would move everything).
  cy.pan(pan);
  cy.zoom(zoom);
}

// ---------------------------------------------------------------------------
// 14. Layout switching
// ---------------------------------------------------------------------------
function setLayout(name) {
  currentLayout = name;
  document.querySelectorAll('.tb-btn[id^="btn-dagre"], .tb-btn[id^="btn-cose"], .tb-btn[id^="btn-circle"]')
    .forEach(b => b.classList.remove('active'));
  const btn = document.getElementById('btn-' + name);
  if (btn) btn.classList.add('active');

  const opts =
    name === 'dagre'
      ? { name: 'dagre', rankDir: 'TB', nodeSep: 30, rankSep: 60, padding: 20 }
    : name === 'cose'
      ? { name: 'cose', idealEdgeLength: 80, nodeRepulsion: 4000, padding: 20, animate: false }
    : { name: 'circle', padding: 20 };

  cy.layout(opts).run();
}

// ---------------------------------------------------------------------------
// 15. NL query (serve mode only — calls the FastAPI backend)
// ---------------------------------------------------------------------------
async function runNLQuery(explain) {
  explain = !!explain;
  const input = document.getElementById('nl-input');
  const query = input.value.trim();
  if (!query) return;

  const loading = document.getElementById('loading');
  loading.classList.add('visible');
  document.getElementById('nl-search-btn').disabled = true;

  try {
    const url = '/api/query?q=' + encodeURIComponent(query) + '&limit=15&explain=' + explain;
    const resp = await fetch(url);
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const data = await resp.json();

    const hitIds = (data.hits || []).map(h => h.node.node_id);
    const matchNodes = cy.nodes().filter(n => hitIds.includes(n.id()));
    applyHighlight(matchNodes);

    if (data.explanation) {
      document.getElementById('explanation-text').textContent = data.explanation;
      document.getElementById('nl-explanation').style.display = 'block';
    }

    if (matchNodes.length > 0) {
      cy.animate({ fit: { eles: matchNodes, padding: 80 } }, { duration: 400 });
    }
  } catch (e) {
    console.error('NL query error:', e);
  } finally {
    loading.classList.remove('visible');
    document.getElementById('nl-search-btn').disabled = false;
  }
}

document.getElementById('nl-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') runNLQuery(false);
});

function closeExplanation() {
  document.getElementById('nl-explanation').style.display = 'none';
}

// ---------------------------------------------------------------------------
// 16. Utility: HTML escaping to prevent XSS in detail panel
// ---------------------------------------------------------------------------
function escHtml(str) {
  if (typeof str !== 'string') str = String(str);
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

// ---------------------------------------------------------------------------
// 17. Hide loading overlay once cytoscape finishes initial layout
// ---------------------------------------------------------------------------
cy.ready(function() {
  document.getElementById('loading').classList.remove('visible');
});

document.getElementById('loading').classList.add('visible');
</script>
</body>
</html>
